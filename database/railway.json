{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "database/Dockerfile",
    "watchPatterns": [
      "database/Dockerfile",
      "database/railway-entrypoint.sh"
    ]
  },
  "deploy": {
    "restartPolicyType": "ALWAYS"
  }
}
