# Copia este archivo como .env y reemplaza los marcadores. No confirmes .env en Git.
DB_HOST=localhost
DB_PORT=1433
DB_NAME=TutorInteligente
DB_USER=sa
DB_PASSWORD=<CONTRASENA_SQL_SERVER>
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true
JWT_SECRET=<SECRETO_ALEATORIO_DE_32_BYTES_O_MAS>
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=
AI_DOCS_ENABLED=true
VITE_API_URL=http://localhost:8080/api
VITE_DEMO_MODE=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEMO_DATA=true
TEACHER_INVITATION_CODE=
RECOVERY_ENABLED=true
RECOVERY_EXPOSE_LOCAL_CODE=true
SWAGGER_ENABLED=true
